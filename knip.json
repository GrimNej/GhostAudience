{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    "apps/studio": {
      "project": ["src/**/*.{ts,tsx}", "worker/**/*.ts", "tests/**/*.{ts,tsx}"]
    },
    "packages/domain": {
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    },
    "packages/contracts": {
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    },
    "packages/parser": {
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    }
  },
  "ignoreBinaries": ["playwright"]
}
